# Comma, space, or newline-separated GitHub usernames to watch.
GITHUB_USERS=octocat,torvalds

# Discord webhook URL. Keep this secret and never commit real values.
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/0000000000000000000/example-token

# Optional GitHub token for higher API rate limits. Public activity is still the only data read.
GITHUB_TOKEN=

# Polling interval for the long-running service.
POLL_INTERVAL_SECONDS=300

# Persisted event IDs used to prevent duplicate Discord notifications.
STATE_FILE=.github-stalker-state.json

# Maximum recent GitHub public events fetched per user on each poll (1-100).
MAX_EVENTS_PER_USER=50

# false = first run records current events without notifying; true = notify historical events currently returned by GitHub.
NOTIFY_ON_STARTUP=false

# true = print Discord payloads instead of sending the webhook. Useful for local smoke checks.
DRY_RUN=false
